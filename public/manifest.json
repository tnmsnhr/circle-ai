{
  "manifest_version": 3,
  "name": "Syncle",
  "version": "1.0.0",
  "description": "Hold ⌘ or Ctrl and lasso areas on any webpage. Selections and chat bubbles stay pinned while you scroll.",
  "permissions": ["tabs", "activeTab", "scripting", "offscreen", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Syncle",
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "background": { "service_worker": "background.js" },
   "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]

}
